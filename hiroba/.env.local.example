# ============================================================
# HIROBA（広場）— コピー:  cp .env.local.example .env.local  （Windows: 手動コピー可）
# 検証: npm run check:env
# ============================================================

# --- Clerk（Dashboard での手作業は下記「Clerk 手動チェックリスト」参照）---
# https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# 既定のログイン後 URL（専用サインインはコンポーネント側で /admin/... へリダイレクト）
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# --- Supabase ---
# https://supabase.com/dashboard → 広場用プロジェクト → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# Publishable（旧 anon）— フロント用
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# service_role — サーバー専用。anon と同じ値にしないこと
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Clerk 手動チェックリスト（ダッシュボード側のみ設定可）
# ============================================================
#
# [1] User & Authentication → 利用するログイン手段（Email / Google 等）を有効化
#
# [2] Configure → Allowed redirect origins（名称は UI により近いもの）
#     開発: http://localhost:3000  （実際のポートに合わせる）
#     本番: https://your-domain.example
#
# [3] ソーシャルログインでリダイレクトを厳格化している場合、次のパスも許可:
#     /sign-in/operator  /sign-up/operator
#     /sign-in/staff     /sign-up/staff
#
# [4] 管理画面に入れるユーザーへ Public metadata を付与（ユーザー詳細 → Metadata）:
#     運営者:
#       { "hirobaAccountKind": "platform_operator" }
#     自治体・登録担当:
#       { "hirobaAccountKind": "municipality_staff" }
#     一般ユーザーは未設定でよい（既定は general 扱い）
#
# 詳細: docs/ROLES_AND_OPERATORS.md
# ============================================================
